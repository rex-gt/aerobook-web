# API Configuration
# For local development the Vite proxy forwards /api requests to localhost:3000.
# You only need to set VITE_API_URL if your backend runs on a different port
# or you are pointing to a remote server.
# VITE_API_URL=http://localhost:3000/api

# For production, set this to your deployed backend URL:
# VITE_API_URL=https://your-railway-app.up.railway.app/api
